@{ ViewData["Title"] = "Kanban Board"; }

<div class="kanban-app">
    <!-- Toolbar -->
    <div class="kanban-toolbar">
        <h1>📋 Kanban Board</h1>
        <div class="toolbar-controls">
            <input type="text" id="searchInput" class="form-control form-control-sm" placeholder="Search cards..." />
            <select id="labelFilter" class="form-select form-select-sm">
                <option value="">All Labels</option>
            </select>
        </div>
    </div>
    <div class="toolbar-manage">
        <div class="project-selector">
            <label for="projectSelect" class="project-selector-label">Project</label>
            <select id="projectSelect" class="form-select form-select-sm" onchange="onProjectChange(this.value)"></select>
        </div>
        <div class="manage-buttons">
            <button class="btn btn-sm btn-outline-secondary" onclick="openProjectManager()">📁 Projects</button>
            <button class="btn btn-sm btn-outline-secondary" onclick="openLabelManager()">🏷️ Labels</button>
            <button class="btn btn-sm btn-outline-secondary" onclick="openPriorityManager()">⚑ Priorities</button>
            <button class="btn btn-sm btn-outline-secondary" onclick="openColumnManager()">🗂️ Columns</button>
        </div>
    </div>

    <!-- Board -->
    <div class="kanban-board" id="kanbanBoard"></div>
</div>

<!-- Card Modal -->
<div class="modal fade" id="cardModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="cardModalTitle">Add Card</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="cardId" />
                <input type="hidden" id="cardColumn" />
                <div class="mb-3">
                    <label for="cardTitle" class="form-label">Title</label>
                    <input type="text" class="form-control" id="cardTitle" required />
                </div>
                <div class="mb-3">
                    <label for="cardDescription" class="form-label">Description</label>
                    <textarea class="form-control" id="cardDescription" rows="3"></textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label">Labels</label>
                    <div id="cardLabels" class="label-checkboxes"></div>
                </div>
                <div class="mb-3">
                    <label for="cardPriority" class="form-label">Priority</label>
                    <select class="form-select form-select-sm" id="cardPriority">
                        <option value="">None</option>
                    </select>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-danger me-auto" id="btnDeleteCard" onclick="deleteCard()" style="display:none">Delete</button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="saveCard()">Save</button>
            </div>
        </div>
    </div>
</div>

<!-- Label Manager Modal -->
<div class="modal fade" id="labelModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Manage Labels</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="labelList" class="mb-3"></div>
                <hr />
                <h6>Add New Label</h6>
                <div class="d-flex gap-2">
                    <input type="text" class="form-control form-control-sm" id="newLabelName" placeholder="Label name" />
                    <input type="color" class="form-control form-control-color form-control-sm" id="newLabelColor" value="#3498db" />
                    <button class="btn btn-sm btn-primary" onclick="createLabel()">Add</button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Column Manager Modal --><div class="modal fade" id="columnModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Manage Columns</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted small mb-2">Drag the ⠿ handle to reorder columns.</p>
                <div id="columnList" class="mb-3"></div>
                <hr />
                <h6>Add New Column</h6>
                <div class="d-flex gap-2">
                    <input type="text" class="form-control form-control-sm" id="newColumnTitle" placeholder="Column title" />
                    <button class="btn btn-sm btn-primary" onclick="createColumn()">Add</button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Priority Manager Modal -->
<div class="modal fade" id="priorityModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Manage Priorities</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="priorityList" class="mb-3"></div>
                <hr />
                <h6>Add New Priority</h6>
                <div class="d-flex gap-2">
                    <input type="text" class="form-control form-control-sm" id="newPriorityName" placeholder="Priority name" />
                    <input type="color" class="form-control form-control-color form-control-sm" id="newPriorityColor" value="#e67e22" />
                    <button class="btn btn-sm btn-primary" onclick="createPriority()">Add</button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Project Manager Modal -->
<div class="modal fade" id="projectModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Manage Projects</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted small mb-2">Each project has its own columns, cards, labels, and priorities.</p>
                <div id="projectList" class="mb-3"></div>
                <hr />
                <h6>Add New Project</h6>
                <div class="d-flex gap-2">
                    <input type="text" class="form-control form-control-sm" id="newProjectName" placeholder="Project name" />
                    <button class="btn btn-sm btn-primary" onclick="createProject()">Add</button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Delete Project Warning Modal -->
<div class="modal fade" id="projectDeleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title text-danger">⚠️ Delete Project</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete the project <strong id="deleteProjectName"></strong>?</p>
                <p class="text-danger mb-0">This permanently removes <strong>all columns, cards, labels, and priorities</strong> that belong to this project. This action cannot be undone.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="btnConfirmDeleteProject" onclick="confirmDeleteProject()">Delete Project</button>
            </div>
        </div>
    </div>
</div>
